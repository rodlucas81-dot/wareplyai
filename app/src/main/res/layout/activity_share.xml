<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0a0f0d">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#075E54"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="WA Reply AI"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/contactName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#c8e6c9"
            android:textSize="13sp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Name selector -->
            <LinearLayout
                android:id="@+id/nameSelectorLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#0f1a16"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:visibility="gone">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WHO ARE YOU IN THIS CHAT?"
                    android:textColor="#25D366"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:paddingBottom="10dp" />
                <LinearLayout
                    android:id="@+id/nameButtonsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

            <!-- Relationship selector -->
            <LinearLayout
                android:id="@+id/relationshipSelectorLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#0f1a16"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="8dp"
                android:visibility="gone">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RELATIONSHIP TO THIS PERSON"
                    android:textColor="#25D366"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:paddingBottom="10dp" />
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">
                    <LinearLayout
                        android:id="@+id/relationshipChipContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" />
                </HorizontalScrollView>
            </LinearLayout>

            <!-- Context + generate -->
            <LinearLayout
                android:id="@+id/contextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="12dp"
                android:paddingBottom="4dp"
                android:visibility="gone">

                <!-- Relationship -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WHO IS THIS PERSON?"
                    android:textColor="#25D366"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:paddingBottom="6dp" />
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:paddingBottom="12dp">
                    <LinearLayout
                        android:id="@+id/relationshipContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" />
                </HorizontalScrollView>

                <!-- Tone -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TONE"
                    android:textColor="#25D366"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:paddingBottom="6dp" />
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:paddingBottom="12dp">
                    <LinearLayout
                        android:id="@+id/toneContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" />
                </HorizontalScrollView>

                <!-- Length -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="REPLY LENGTH"
                    android:textColor="#25D366"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:paddingBottom="6dp" />
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:paddingBottom="12dp">
                    <LinearLayout
                        android:id="@+id/lengthContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" />
                </HorizontalScrollView>

                <!-- Context -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ADD CONTEXT (optional)"
                    android:textColor="#25D366"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:paddingBottom="6dp" />
                <EditText
                    android:id="@+id/contextInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/card_bg"
                    android:textColor="#e8e8e8"
                    android:textColorHint="#555555"
                    android:textSize="14sp"
                    android:padding="12dp"
                    android:hint="e.g. she seems upset, we had a fight..."
                    android:inputType="textMultiLine"
                    android:minLines="2"
                    android:maxLines="4"
                    android:gravity="top" />
                <Button
                    android:id="@+id/generateBtn"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="10dp"
                    android:text="✨ Get Reply Suggestions"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:background="@drawable/btn_green" />
            </LinearLayout>

            <!-- Personal question card -->
            <LinearLayout
                android:id="@+id/personalQuestionLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#0d1f15"
                android:layout_margin="12dp"
                android:padding="16dp"
                android:visibility="gone">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="QUICK ANSWER NEEDED"
                    android:textColor="#25D366"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:paddingBottom="10dp" />
                <TextView
                    android:id="@+id/personalQuestionText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#c8e6c9"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp"
                    android:paddingBottom="12dp" />
                <EditText
                    android:id="@+id/personalAnswerInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/card_bg"
                    android:textColor="#e8e8e8"
                    android:textColorHint="#555555"
                    android:textSize="14sp"
                    android:padding="12dp"
                    android:hint="Your answer..."
                    android:inputType="textMultiLine"
                    android:minLines="2"
                    android:maxLines="5"
                    android:gravity="top" />
                <Button
                    android:id="@+id/submitAnswerBtn"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="10dp"
                    android:text="Generate Replies"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:background="@drawable/btn_green" />
            </LinearLayout>

            <!-- Loading -->
            <LinearLayout
                android:id="@+id/loadingLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:padding="20dp"
                android:visibility="gone">
                <ProgressBar
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:indeterminateTint="#25D366" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Analyzing conversation..."
                    android:textColor="#8aae9b"
                    android:textSize="14sp"
                    android:paddingStart="12dp" />
            </LinearLayout>

            <!-- Error -->
            <TextView
                android:id="@+id/errorText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#ff9999"
                android:textSize="13sp"
                android:padding="16dp"
                android:background="#1a0f0f"
                android:visibility="gone" />

            <!-- Results -->
            <LinearLayout
                android:id="@+id/resultsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp" />

        </LinearLayout>
    </ScrollView>

    <!-- Refinement bar - shown after results -->
    <LinearLayout
        android:id="@+id/refinementLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0f1a16"
        android:padding="10dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="REFINE REPLIES"
            android:textColor="#25D366"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:paddingBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/refinementInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/card_bg"
                android:textColor="#e8e8e8"
                android:textColorHint="#555555"
                android:textSize="14sp"
                android:padding="10dp"
                android:hint="make it shorter, add a joke, less formal..."
                android:inputType="text"
                android:maxLines="1"
                android:imeOptions="actionSend" />

            <Button
                android:id="@+id/refinementBtn"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:text="→"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:background="@drawable/btn_green"
                android:padding="0dp" />

        </LinearLayout>

        <!-- Quick suggestion chips -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:scrollbars="none">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:id="@+id/chipContainer" />
        </HorizontalScrollView>

    </LinearLayout>

</LinearLayout>
